{
  "name": "instaclone",
  "version": "2.0.0",
  "description": "A full-stack Instagram clone built with the MERN stack (MongoDB, Express, React, Node.js) – modernized 2026 edition",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "server": "nodemon index.js",
    "client": "cd client && npm run start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "heroku-postbuild": "cd client && npm install --include=dev && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MegaNumber/Instagram-clone.git"
  },
  "keywords": [
    "instagram-clone",
    "mern",
    "react",
    "nodejs",
    "express",
    "mongodb",
    "socket.io",
    "social-media"
  ],
  "author": "Sandermoen & Contributors",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/MegaNumber/Instagram-clone/issues"
  },
  "homepage": "https://github.com/MegaNumber/Instagram-clone#readme",
  "dependencies": {
    "async-retry": "^1.3.3",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.0",
    "express-validator": "^7.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "linkifyjs": "^4.1.1",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.5",
    "sharp": "^0.32.6",
    "socket.io": "^4.7.2",
    "validator": "^13.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.2"
  }
}
