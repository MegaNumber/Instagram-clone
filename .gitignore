# ============================================================
# فایل: .gitignore
# توضیح: فهرست فایل‌ها و پوشه‌هایی که نباید وارد کنترل نسخه (Git) شوند.
# ============================================================

# ---------- ۱. وابستگی‌ها ----------
node_modules/
/client/node_modules/

# ---------- ۲. فایل‌های محیطی و امنیتی ----------
.env
.env.local
.env.production

# ---------- ۳. فایل‌های آپلودشده (حجیم و تولیدی) ----------
/public/uploads/*
!/public/uploads/.gitkeep

# ---------- ۴. لاگ‌ها ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ---------- ۵. پوشه‌های تولید (build) ----------
/client/build/
/dist/
/build/

# ---------- ۶. سیستم‌عامل ----------
.DS_Store
Thumbs.db

# ---------- ۷. پوشه‌های مربوط به Docker (اختیاری) ----------
# docker-compose.override.yml   # اگر فایل override شخصی دارید
# data/                         # اگر داده‌های دیتابیس را داخل پروژه mount می‌کنید

# ---------- ۸. پوشه‌های موقت ----------
temp/
/tmp/
