# مسیر فایل: /Dockerfile
# توضیح: فایل Docker برای ساخت ایمیج سرور Express (بک‌اند Instaclone)
# از یک ایمیج سبک Node.js استفاده می‌کند و وابستگی‌ها را نصب می‌کند.

# ======================================
# مرحله ۱: انتخاب ایمیج پایه
# ======================================
FROM node:18-alpine

# ======================================
# مرحله ۲: نصب ffmpeg برای پردازش ویدیو
# ======================================
RUN apk add --no-cache ffmpeg

# ======================================
# مرحله ۳: ایجاد پوشه کاری
# ======================================
WORKDIR /usr/src/app

# ======================================
# مرحله ۴: کپی فایل‌های وابستگی
# ======================================
COPY package*.json ./

# ======================================
# مرحله ۵: نصب وابستگی‌ها
# ======================================
RUN npm ci --only=production

# ======================================
# مرحله ۶: کپی سورس کد
# ======================================
COPY . .

# ======================================
# مرحله ۷: ایجاد پوشه‌های مورد نیاز
# ======================================
RUN mkdir -p public/uploads/avatars \
             public/uploads/posts \
             public/uploads/thumbnails \
             public/uploads/stories/images \
             public/uploads/stories/videos \
             public/uploads/videos \
             public/uploads/chat \
             temp

# ======================================
# مرحله ۸: تنظیم متغیرهای محیطی پیش‌فرض
# ======================================
ENV NODE_ENV=production

# ======================================
# مرحله ۹: باز کردن پورت
# ======================================
EXPOSE 5000

# ======================================
# مرحله ۱۰: اجرای سرور
# ======================================
CMD ["node", "index.js"]
